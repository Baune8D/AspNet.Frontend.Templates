{
  "version": "1.0.0",
  "name": "aspnet-mvc-webpack-typescript",
  "description": "This project is a template for using ASP.NET MVC with Webpack and TypeScript.",
  "private": true,
  "scripts": {
    "build": "cross-env NODE_OPTIONS='--loader=ts-node/esm --disable-warning=ExperimentalWarning --disable-warning=DEP0180' webpack --mode=production",
    "start": "cross-env NODE_OPTIONS='--loader=ts-node/esm --disable-warning=ExperimentalWarning --disable-warning=DEP0180' webpack serve --mode=development"
  },
