    "jquery-validation-unobtrusive": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/webpack": "^5.28.5",
    "aspnet-buildtools": "^0.3.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "fork-ts-checker-webpack-plugin": "~9.0.3",
    "mini-css-extract-plugin": "^2.10.2",
